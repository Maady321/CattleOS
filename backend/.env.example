# ==================================================
# CattleOS - Backend Environment Configuration (EXAMPLE)
# ==================================================

# Security
SECRET_KEY=YOUR_PRODUCTION_SECRET_KEY
ACCESS_TOKEN_EXPIRE_MINUTES=15

# Database
POSTGRES_SERVER=db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=YOUR_STRONG_PASSWORD
POSTGRES_DB=cattleos

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# Services
SUPABASE_URL=YOUR_SUPABASE_URL
SUPABASE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
SMTP_USER=
SMTP_PASSWORD=
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
